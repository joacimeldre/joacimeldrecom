---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
const { frontmatter } = Astro.props;
const normalizedTags = (frontmatter.tags ?? [])
  .map((tag: string) => tag.trim())
  .filter((tag: string) => tag.length > 0);

// Get the resolved image src for meta tags
const imageUrl = frontmatter.image?.url?.src || "/ogdefault.png";

const formattedDate = (() => {
  const pubDate = frontmatter.pubDate;

  // If it's already a Date object, use it directly
  const date = pubDate instanceof Date ? pubDate : new Date(pubDate);

  const year = date.getUTCFullYear();
  const monthName = date.toLocaleDateString("en-US", {
    month: "short",
    timeZone: "UTC",
  });
  const day = date.getUTCDate();

  return `${monthName} ${day}, ${year}`;
})();
---

<BaseLayout
  title={`${frontmatter.title} - Joacim Eldre`}
  description={frontmatter.description}
  image={imageUrl}
  type="article"
  publishedTime={frontmatter.pubDate}
>
  <section>
    <div class="py-24 max-w-3xl">
      <div>
        <div class="mx-auto">
          <h1 class="typo-display-xl">
            {frontmatter.title}
          </h1>
          <p class="mt-3 typo-main">
            {frontmatter.description}
          </p>
          <Image
            width={1280}
            height={630}
            src={frontmatter.image.url}
            alt={frontmatter.image.alt}
            loading="eager"
            fetchpriority="high"
            sizes="(max-width: 768px) 100vw, 768px"
            style="display:block;width:100%;height:auto;aspect-ratio:1280 / 630;object-fit:cover;object-position:center;margin-top:1rem;margin-left:auto;margin-right:auto;border-radius:0.75rem;"
          />
          <p class="mx-auto mt-4 typo-nav">
            Published on <time datetime={frontmatter.pubDate}
              >{formattedDate}</time
            >
          </p>
          <p class="mx-auto mt-2 typo-nav">
            Tagged as{" "}
            {
              normalizedTags.map((tag: string, index: number) => (
                <>
                  {index > 0 && " & "}
                  <a href={`/tags/${encodeURIComponent(tag)}`} class="typo-nav">{tag}</a>
                </>
              ))
            }
          </p>
        </div>

        <div class="typo-main prose typo-prose max-w-3xl mt-12 mx-auto">
          <slot />
        </div>

        <div class="mx-auto mt-12 text-base-900/70">
          <div class="group inline-flex items-center gap-3 rounded-md border border-base-900/25 px-3 py-2 transition-colors duration-200 hover:border-base-900/60 hover:cursor-pointer" data-clap-button role="button" tabindex="0">
            <button
              type="button"
              class="clap-button relative inline-flex items-center gap-2 px-0 py-0 typo-ui text-base-900/70 transition duration-200 hover:text-base-900 cursor-pointer disabled:cursor-default disabled:text-base-900/50"
              aria-live="polite"
            >
              <span aria-hidden="true">👏🏻</span>
              <span data-clap-count class="inline-block min-w-[3ch] text-center tabular-nums">0</span>
              <span class="sr-only">claps</span>
              <span class="clap-burst" data-clap-burst aria-hidden="true">
                <span class="clap-line clap-line-1"></span>
                <span class="clap-line clap-line-2"></span>
                <span class="clap-line clap-line-3"></span>
                <span class="clap-line clap-line-4"></span>
                <span class="clap-line clap-line-5"></span>
                <span class="clap-line clap-line-6"></span>
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const clapContainer = document.querySelector(
      "[data-clap-button]",
    ) as HTMLElement | null;
    const clapCount = document.querySelector("[data-clap-count]");
    const clapBurst = document.querySelector("[data-clap-burst]");

    if (clapContainer && clapCount && clapBurst) {
      const isDev = import.meta.env.DEV;

      // Extract slug from pathname (e.g., /posts/my-post-title/ -> my-post-title)
      const pathname = window.location.pathname;
      const slug = pathname.split("/").filter(Boolean).pop() || "";
      const clapLockKey = `claps:locked:${pathname}`;

      let claps = 0;
      let isLoading = true;
      let hasClappedLocally = localStorage.getItem(clapLockKey) === "1";

      const renderClaps = () => {
        clapCount.textContent = String(claps);
        const isDisabled = !isDev && hasClappedLocally;
        clapContainer.setAttribute("aria-label", `Clap for this post (${claps} claps)`);
        clapContainer.setAttribute("aria-disabled", String(isDisabled));
      };

      // Fetch initial clap count from server
      const fetchClaps = async () => {
        try {
          const response = await fetch(`/api/claps/${slug}`);
          if (response.status === 404) {
            return;
          }
          if (response.ok) {
            const data = await response.json();
            claps = data.count || 0;

            // If count is zero but browser says user has clapped, the local lock is stale.
            if (!isDev && hasClappedLocally && claps === 0) {
              hasClappedLocally = false;
              localStorage.removeItem(clapLockKey);
            }
          }
        } catch (error) {
          // Claps API can be unavailable in static previews; fail silently.
        } finally {
          isLoading = false;
          renderClaps();
        }
      };

      fetchClaps();

      const playClapBurst = () => {
        clapBurst.classList.remove("clap-burst-active");
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            clapBurst.classList.add("clap-burst-active");
          });
        });
      };

      const handleClap = async () => {
        if (isLoading || (!isDev && hasClappedLocally)) return;

        // Optimistic update
        hasClappedLocally = true;
        if (!isDev) {
          localStorage.setItem(clapLockKey, "1");
        }
        claps += 1;
        renderClaps();
        playClapBurst();

        try {
          const response = await fetch(`/api/claps/${slug}`, { method: "POST" });
          if (response.ok) {
            const data = await response.json();
            claps = data.count;

            if (data.blocked && !isDev) {
              hasClappedLocally = true;
              localStorage.setItem(clapLockKey, "1");
            }

            renderClaps();
          } else {
            throw new Error(`Clap request failed with status ${response.status}`);
          }
        } catch (error) {
          console.error("Failed to increment claps:", error);
          // Revert optimistic update on error
          claps -= 1;
          hasClappedLocally = false;
          if (!isDev) {
            localStorage.removeItem(clapLockKey);
          }
          renderClaps();
          return;
        }
      };

      clapContainer.addEventListener("click", handleClap);
      clapContainer.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          handleClap();
        }
      });
    }

    document
      .querySelectorAll('.prose input[type="checkbox"]')
      .forEach((checkbox) => {
        const input = checkbox as HTMLInputElement;
        input.disabled = false;

        // Wrap checkbox text in a label
        const listItem = input.closest("li");
        if (listItem && !input.parentElement?.matches("label")) {
          const label = document.createElement("label");

          // Get the text after the checkbox
          const textContent = Array.from(listItem.childNodes)
            .filter(
              (node) => node !== input && node.nodeType === Node.TEXT_NODE,
            )
            .map((node) => node.textContent)
            .join("")
            .trim();

          listItem.textContent = "";
          label.appendChild(input);
          label.appendChild(document.createTextNode(" " + textContent));
          listItem.appendChild(label);
        }

        // Load and save state
        const taskId = input.closest("li")?.textContent?.trim() || "";
        const savedState = localStorage.getItem(`task-${taskId}`);
        if (savedState === "true") {
          input.checked = true;
        }

        // Function to toggle strikethrough
        const toggleStrikethrough = () => {
          const label = input.closest("label");
          if (label) {
            if (input.checked) {
              label.style.textDecoration = "line-through";
            } else {
              label.style.textDecoration = "none";
            }
          }
        };

        // Apply initial state
        toggleStrikethrough();

        input.addEventListener("change", () => {
          const taskId = input.closest("li")?.textContent?.trim() || "";
          localStorage.setItem(`task-${taskId}`, input.checked.toString());
          toggleStrikethrough();
        });
      });
  </script>
</BaseLayout>
