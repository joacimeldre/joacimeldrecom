---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
const { frontmatter } = Astro.props;

// Get the resolved image src for meta tags
const imageUrl = frontmatter.image?.url?.src || "/ogdefault.png";

const formattedDate = (() => {
  const pubDate = frontmatter.pubDate;

  // If it's already a Date object, use it directly
  const date = pubDate instanceof Date ? pubDate : new Date(pubDate);

  const year = date.getFullYear();
  const monthName = date.toLocaleDateString("en-US", { month: "short" });
  const day = String(date.getDate()).padStart(2, "0");

  return `${year} ${monthName} ${day}`;
})();
---

<BaseLayout
  title={`${frontmatter.title} - Joacim Eldre`}
  description={frontmatter.description}
  image={imageUrl}
  type="article"
>
  <section>
    <div class="py-24 max-w-3xl">
      <div>
        <div class="mx-auto">
          <h1 class="text-4xl font-medium font-display text-base-900">
            {frontmatter.title}
          </h1>
          <p class="mt-4 text-base-900 text-xl">
            {frontmatter.description}
          </p>
          <Image
            width={1280}
            height={630}
            src={frontmatter.image.url}
            alt={frontmatter.image.alt}
            class="object-cover object-center w-full rounded-xl mt-4"
          />
          <p class="mx-auto mt-4 text-base-900 text-sm">
            Published on <time datetime={frontmatter.pubDate}
              >{formattedDate}</time
            >
          </p>
          <p class="flex gap-1 mx-auto mt-2 text-base-900 text-sm">
            Tagged as
            {
              frontmatter.tags.map((tag, index) => (
                <span>
                  <a
                    href={`/tags/${tag}`}
                    class="underline hover:decoration-wavy"
                  >
                    {tag}
                  </a>
                  {index < frontmatter.tags.length - 1 && " & "}
                </span>
              ))
            }
          </p>
        </div>

        <div class="prose max-w-3xl mt-12 mx-auto text-base-900">
          <slot />
        </div>
      </div>
    </div>
  </section>

  <script>
    document
      .querySelectorAll('.prose input[type="checkbox"]')
      .forEach((checkbox) => {
        const input = checkbox as HTMLInputElement;
        input.disabled = false;

        // Wrap checkbox text in a label
        const listItem = input.closest("li");
        if (listItem && !input.parentElement?.matches("label")) {
          const label = document.createElement("label");

          // Get the text after the checkbox
          const textContent = Array.from(listItem.childNodes)
            .filter(
              (node) => node !== input && node.nodeType === Node.TEXT_NODE,
            )
            .map((node) => node.textContent)
            .join("")
            .trim();

          listItem.textContent = "";
          label.appendChild(input);
          label.appendChild(document.createTextNode(" " + textContent));
          listItem.appendChild(label);
        }

        // Load and save state
        const taskId = input.closest("li")?.textContent?.trim() || "";
        const savedState = localStorage.getItem(`task-${taskId}`);
        if (savedState === "true") {
          input.checked = true;
        }

        // Function to toggle strikethrough
        const toggleStrikethrough = () => {
          const label = input.closest("label");
          if (label) {
            if (input.checked) {
              label.style.textDecoration = "line-through";
            } else {
              label.style.textDecoration = "none";
            }
          }
        };

        // Apply initial state
        toggleStrikethrough();

        input.addEventListener("change", () => {
          const taskId = input.closest("li")?.textContent?.trim() || "";
          localStorage.setItem(`task-${taskId}`, input.checked.toString());
          toggleStrikethrough();
        });
      });
  </script>
</BaseLayout>
