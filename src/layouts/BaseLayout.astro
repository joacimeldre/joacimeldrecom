---
import BaseHead from "@/components/BaseHead.astro";
import Navigation from "@/components/global/Navigation.astro";
import Footer from "@/components/global/Footer.astro";
import BallSling from "@/components/global/BallSling.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string | Date;
  showBallSling?: boolean;
}

const { title, description, image, type, publishedTime, showBallSling = true } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishedTime={publishedTime}
    />
  </head>
  <body class="flex flex-col max-w-3xl min-h-screen px-8 mx-auto">
    <Navigation />
    <main class="grow typo-main-size"><slot /></main>
    <Footer />
    {showBallSling && <BallSling />}
    <script is:inline>
      const assignRotatingLinkColors = () => {
        const links = document.querySelectorAll(
          "a:not(.rounded-full):not(.logo-link):not(.nav-link):not(.tag-link)",
        );
        const tokens = ["1", "2", "3", "4"];

        links.forEach((link, index) => {
          const token = tokens[index % tokens.length];
          link.dataset.lc = token;
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", assignRotatingLinkColors, {
          once: true,
        });
      } else {
        assignRotatingLinkColors();
      }

      document.addEventListener("astro:after-swap", assignRotatingLinkColors);
    </script>
  </body>
</html>
