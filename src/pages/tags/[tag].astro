---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogEntries from "@/components/entries/BlogEntry.astro";
import { getCollection, type CollectionEntry } from "astro:content";
export const prerender = true;

export async function getStaticPaths() {
  const allPosts = await getCollection("posts");
  const uniqueTags = [
    ...new Set(allPosts.map((post) => post.data.tags).flat()),
  ];

  return uniqueTags.map((tag) => {
    // Filter posts by tag
    const filteredPosts = allPosts.filter((post) =>
      post.data.tags.includes(tag),
    );
    // Sort filtered posts by date in descending order
    const sortedPosts = filteredPosts.sort(
      (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
    );

    return {
      params: { tag },
      props: { posts: sortedPosts },
    };
  });
}

const allPosts = await getCollection("posts");
const tagAccentColors = ["#ff5fa2", "#ffc800", "#5f71ff", "#39edae"] as const;
const getTagAccentColor = (index: number) =>
  tagAccentColors[index % tagAccentColors.length];

// Sort tags by name in alphabetical order, ignoring case sensitivity
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())].sort(
  (a, b) => a.toLowerCase().localeCompare(b.toLowerCase()),
);

const { tag } = Astro.params;
const { posts } = Astro.props as { posts: CollectionEntry<"posts">[] };
const activeTagIndex = tags.findIndex((currentTag) => currentTag === tag);
const activeTagAccentColor = getTagAccentColor(
  activeTagIndex === -1 ? 0 : activeTagIndex,
);
---

<BaseLayout title={`${tag} posts - Joacim Eldre`}>
  <section>
    <div class="py-24">
      <h1
        class="typo-display-xl mb-2"
      >
        Show posts tagged with
      </h1>
      <div class="flex flex-wrap gap-3 mt-2">
        {
          tags.map((t) => {
            const isActive = t === tag;
            const classes = isActive
              ? "font-bold typo-main"
              : "typo-main";

            return (
              <a class={classes} href={`/tags/${encodeURIComponent(t)}`}>
                {t}
              </a>
            );
          })
        }
      </div>
      <h2
        class="typo-display-lg max-w-xl mt-8"
      >
        ö <span class="px-2 rounded" style={`background-color: ${activeTagAccentColor}`}>{tag}</span>
      </h2>
      <ul class="mt-4">
        {
          posts.map((post) => (
            <BlogEntries
              url={"/posts/" + post.id.replace(/\.(md|mdx)$/i, "")}
              title={post.data.title}
              pubDate={post.data.pubDate.toISOString().split("T")[0]}
            />
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
