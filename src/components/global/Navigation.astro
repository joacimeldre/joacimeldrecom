---
import { Image } from "astro:assets";
import logo from "../../content/images/logo.svg";
---

<div
  class="mt-6 relative flex flex-row w-full mx-auto items-center justify-between"
>
  <div>
    <a href="/" aria-label="Home" class="decoration-none">
      <Image src={logo} alt="Joacim Eldre Logo" class="h-5 w-auto" />
    </a>
  </div>
  <nav class="flex ml-auto gap-4 items-center">
    <a
      href="/about"
      class="underline text-base-900 text-sm transition duration-200 hover:decoration-wavy"
    >
      About
    </a>
    <a
      aria-label="Contact me"
      href="mailto:hei@joacimeldre.com"
      class="bg-amber-200 text-base-900 py-2 px-4 rounded-full text-sm transition duration-200 hover:bg-white hover:text-base-900"
      >Hello <span aria-hidden="true" class="inline-block wave-hand">👋🏻</span
      ></a
    >
  </nav>
</div>

<style>
  @keyframes wave {
    0% {
      transform: rotate(0deg);
    }
    10% {
      transform: rotate(14deg);
    }
    20% {
      transform: rotate(-8deg);
    }
    30% {
      transform: rotate(14deg);
    }
    40% {
      transform: rotate(-4deg);
    }
    50% {
      transform: rotate(10deg);
    }
    60% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }

  .wave-hand {
    transform-origin: 50% 50%;
  }

  a:hover .wave-hand {
    animation: wave 2s ease-in-out infinite;
  }
</style>
