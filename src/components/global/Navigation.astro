---
import { Image } from "astro:assets";
import logo from "../../content/images/logo_normal.svg";

const isAboutActive = Astro.url.pathname === "/about" || Astro.url.pathname === "/about/";
---

<div
  class="mt-5 relative flex flex-row w-full mx-auto items-center justify-between"
>
  <div>
    <a href="/" aria-label="Home" class="logo-link">
      <Image
        src={logo}
        alt="Joacim Eldre Logo"
        width={32}
        height={32}
        class="h-8 w-8 max-w-none block"
      />
    </a>
  </div>
  <nav class="flex ml-auto items-center gap-3 sm:gap-5">
    <a
      href="/about"
      class:list={["typo-nav nav-link transition duration-200", { "font-bold": isAboutActive }]}
      aria-current={isAboutActive ? "page" : undefined}
    >
      About
    </a>
    <a
      href="mailto:hei@joacimeldre.com"
      class="button-link bg-accent text-base-900 typo-nav py-2 px-3 sm:px-4 rounded-full transition duration-200 hover:bg-base-900 hover:text-base-50"
      >Hello <span aria-hidden="true">:)</span></a
    >
  </nav>
</div>
