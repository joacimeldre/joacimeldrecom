---
import logoSrc from "../../content/images/logo_normal.svg";

interface Props {
  alt?: string;
  width?: number;
  height?: number;
  class?: string;
  style?: string;
  ariaHidden?: boolean;
}

const DEFAULT_LOGO_ALT = "Joacim Eldre logo";

const {
  alt = DEFAULT_LOGO_ALT,
  width = 32,
  height = 32,
  class: className,
  style,
  ariaHidden,
} = Astro.props;

const src = typeof logoSrc === "string" ? logoSrc : logoSrc.src;
---

<img
  src={src}
  alt={alt}
  width={width}
  height={height}
  class={className}
  style={style}
  aria-hidden={ariaHidden}
/>