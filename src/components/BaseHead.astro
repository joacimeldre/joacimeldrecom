---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: "website" | "article";
  publishedTime?: string | Date;
}

const {
  title = "Joacim Eldre",
  description = "If this description shows, it means that Joacim forgot to set a description, boo! Hehe.",
  image = "/ogdefault.png",
  canonical = Astro.url.href,
  type = "website",
  publishedTime,
} = Astro.props;

const fullImageUrl = image.startsWith("http")
  ? image
  : new URL(image, Astro.site || Astro.url.origin).href;

const structuredData =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description,
        image: [fullImageUrl],
        url: canonical,
        ...(publishedTime
          ? {
              datePublished:
                publishedTime instanceof Date
                  ? publishedTime.toISOString()
                  : new Date(publishedTime).toISOString(),
            }
          : {}),
        author: {
          "@type": "Person",
          name: "Joacim Eldre",
          url: Astro.site || Astro.url.origin,
        },
      }
    : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Joacim Eldre",
        description,
        url: Astro.site || Astro.url.origin,
        inLanguage: "en-US",
      };
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />

<meta name="robots" content="index,follow,max-image-preview:large" />
<meta name="googlebot" content="index,follow,max-image-preview:large" />
<meta name="theme-color" content="#fff8e7" />

<!-- Favicons -->
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link
  rel="icon"
  type="image/png"
  sizes="192x192"
  href="/android-chrome-192x192.png"
/>
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

<link rel="canonical" href={canonical} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content="Joacim Eldre" />
<meta property="og:locale" content="en_US" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />

{publishedTime && (
  <meta
    property="article:published_time"
    content={
      publishedTime instanceof Date
        ? publishedTime.toISOString()
        : new Date(publishedTime).toISOString()
    }
  />
)}

<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
