---
const { title, url, pubDate } = Astro.props;

const formattedDate = (() => {
  // pubDate comes in as a string like "2026-01-19"
  const [year, month, day] = pubDate.split("-");
  // Create date properly to avoid timezone issues
  const date = new Date(year, month - 1, day);
  const monthName = date.toLocaleDateString("en-US", { month: "short" });

  return `${monthName} ${Number(day)}, ${year}`;
})();
---

<li class="py-1.5">
  <div class="grid grid-cols-1 gap-y-0.5 text-base text-base-900 sm:grid-cols-[6.5rem_minmax(0,1fr)] sm:items-baseline sm:gap-x-3">
    <time datetime={pubDate} class="text-base-900/60">
      {formattedDate}
    </time>
    <a
      href={url}
      class="min-w-0 underline hover:decoration-wavy decoration-1 underline-offset-3"
    >
      {title}
    </a>
  </div>
</li>
