---
const { title, url, pubDate } = Astro.props;

const formattedDate = (() => {
  // pubDate comes in as a string like "2026-01-19"
  const [year, month, day] = pubDate.split("-");
  // Create date properly to avoid timezone issues
  const date = new Date(year, month - 1, day);
  const monthName = date.toLocaleDateString("en-US", { month: "short" });

  return `${monthName} ${Number(day)}, ${year}`;
})();
---

<li class="grid grid-cols-1 gap-y-0.5 py-1.5 sm:grid-cols-[max-content_minmax(0,1fr)] sm:items-baseline sm:gap-x-[4px]">
  <time datetime={pubDate} class="typo-main-muted proportional-nums sm:self-baseline">
    {formattedDate}
  </time>
  <a
    href={url}
    class="min-w-0 typo-main underline hover:decoration-wavy decoration-1 underline-offset-3"
  >
    {title}
  </a>
</li>
